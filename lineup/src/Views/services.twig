{% extends 'base.twig' %}
{% block title %}Services{% endblock %}
{% block content %}
<div class="services-page">
  <section class="py-5 text-center container">
    <div class="row py-lg-5">
      <div class="col-lg-6 col-md-8 mx-auto">
        <h1 class="fw-bold">Our Services</h1>
      </div>
    </div>
  </section>
  <div class="album py-5 bg-light">
    <div class="container">
      <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">

        {% for service in services %}
        <div class="col">
          <div class="card shadow-sm">
          <img src=https://images.unsplash.com/photo-1621605815971-fbc98d665033?q=80&w=2670&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D class="card-img-top" alt="{{ service.name}}">
            <div class="card-body">
            <h5 class = "card-title"> {{ service.name }} </h5>
              <p class="card-text">{{ service.description }}</p>
              <div class="d-flex justify-content-between align-items-center">
                <div class="btn-group">
                {% if session.user is defined and session.user.role == 'admin' %}
                  <a href="/admin/services" class="btn btn-sm btn-outline-secondary">Edit</a>
                  <form action="/admin/services/delete/{{ service.id }}" method=post>
                    <button type="submit" class="btn btn-sm btn-outline-secondary">Delete</button>
                  </form>
                {% else %}
                  <a href="/book" class="btn btn-sm btn-outline-secondary">Book</a>
                {% endif %}
                </div>
                <small class="text-muted">${{ service.price }}</small>
              </div>
            </div>
          </div>
        </div>
        {% endfor %}
        
      </div>
    </div>
  </div>
  </div>
{% endblock %}